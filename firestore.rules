rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Global Helper Functions
    // ===============================================================

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isRecent(ts) { return ts != null && ts > request.time - duration.value(5, 'm') && ts <= request.time; }

    // ===============================================================
    // Validation Blueprints
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'language', 'skillLevel', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             data.language is string &&
             data.skillLevel in ['Beginner', 'Intermediate', 'Pro'] &&
             data.updatedAt is timestamp;
    }

    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'userName', 'imageUrl', 'rating', 'createdAt', 'likesCount', 'commentsCount']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 50 &&
             data.imageUrl is string && data.imageUrl.size() < 1024 &&
             data.rating >= 1 && data.rating <= 5 &&
             data.likesCount is int && data.likesCount >= 0 &&
             data.commentsCount is int && data.commentsCount >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['userId', 'userName', 'text', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidShare(data) {
      return data.keys().hasAll(['shareId', 'userId', 'recipeId', 'platform', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.platform is string && data.platform.size() <= 50 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Match Blocks
    // ===============================================================

    // Public Profiles & Private User Data
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow profile fetching
      allow list: if false; // No blanket user listing
      
      allow create: if isOwner(userId) && isVerified() && isValidUser(incoming()) && 
                    incoming().createdAt is timestamp && isRecent(incoming().createdAt);
      allow update: if isOwner(userId) && isVerified() && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    (incoming().createdAt == existing().createdAt || isRecent(incoming().createdAt)) &&
                    incoming().updatedAt == request.time;

      match /savedRecipes/{recipeId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /searchHistory/{searchId} {
        allow read, create: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, delete: if isOwner(userId);
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      }
      
      // Followers/Following
      match /followers/{followerId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(followerId) && isValidId(userId);
      }
      
      match /following/{followingId} {
        allow read: if isSignedIn();
        allow create, delete: if isOwner(userId) && isValidId(followingId);
      }
    }

    // Social Feed
    match /posts/{postId} {
      allow get, list: if true; // Allow public viewing of the food feed
      allow create: if isSignedIn() && isValidPost(incoming()) && isRecent(incoming().createdAt);
      allow update: if (isOwner(existing().userId) && isValidPost(incoming()) && 
                        incoming().userId == existing().userId &&
                        incoming().createdAt == existing().createdAt) ||
                    // Action: Like/Unlike (Only increment/decrement likesCount)
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
                     incoming().likesCount is int) ||
                    // Action: Comment (Only increment commentsCount)
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['commentsCount']) &&
                     incoming().commentsCount is int);
      allow delete: if isOwner(existing().userId);

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidComment(incoming()) && isRecent(incoming().createdAt);
        allow delete: if isOwner(existing().userId) || isOwner(get(/databases/$(database)/documents/posts/$(postId)).data.userId);
      }

      match /likes/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId) && isValidLike(incoming());
      }
    }

    // Analytics
    match /shareAnalytics/{shareId} {
      allow create: if isSignedIn() && isValidShare(incoming()) && isRecent(incoming().timestamp);
      allow read: if false; // Analytics are write-only for clients
    }
  }
}
